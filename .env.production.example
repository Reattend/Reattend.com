# ── App ───────────────────────────────────────────────
NEXTAUTH_URL=https://reattend.com
NEXTAUTH_SECRET=           # openssl rand -base64 32
DATABASE_PATH=/var/www/reattend/data/reattend.db

# ── AI Provider (LLM only — embeddings are local on desktop) ──
GROQ_API_KEY=
ASSEMBLYAI_API_KEY=  # https://www.assemblyai.com — used for meeting transcription (Nano model)

# ── Auth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Resend) ───────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Reattend <noreply@reattend.com>

# ── Billing (Paddle) ────────────────────────────────
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_PRICE_ID=
